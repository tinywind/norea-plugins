{
  "name": "norea-plugins",
  "version": "0.1.0",
  "description": "Legal-safe sample plugins for Norea",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:start": "node scripts/generate-plugin-index.js && vite",
    "build:compile": "npx tsc --project tsconfig.production.json",
    "build:manifest": "node ./scripts/build-plugin-manifest.js",
    "build:manifest:dev": "node --env-file=.env ./scripts/build-plugin-manifest.js --include-dev",
    "build:icons": "node scripts/generate-plugin-index.js && npm run build:compile && npm run build:manifest && node ./scripts/download-plugin-icons.js",
    "build:full": "node scripts/generate-plugin-index.js && npm run build:compile && npm run build:manifest",
    "hooks:install": "git config core.hooksPath .githooks",
    "publish:plugins": "chmod +x ./scripts/publish-plugins.sh && ./scripts/publish-plugins.sh",
    "publish:plugins:windows": "powershell ./scripts/publish-plugins.ps1",
    "serve:dev": "npm run build:compile && npm run build:manifest:dev && serve",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "prettier --write \"./**/*.{js,ts}\"",
    "format:check": "prettier --check \"./**/*.{js,ts}\"",
    "verify:commit": "npm run format:check && npm run lint && npm run build:compile",
    "verify:plugins": "node scripts/verify-plugin-artifacts.js"
  },
  "author": "Norea",
  "license": "MIT",
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@noble/ciphers": "^2.2.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "terser": "^5.47.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "htmlparser2": "^12.0.0",
    "husky": "^9.1.7",
    "image-size": "^2.0.2",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "protobufjs": "^8.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.2.0",
    "react-virtuoso": "^4.18.7",
    "react-window": "^2.2.7",
    "sanitize-html": "^2.17.4",
    "serve": "^14.2.6",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.59.3",
    "urlencode": "^2.0.0",
    "vite": "^8.0.13",
    "zustand": "^5.0.13"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": "prettier --write"
  },
  "overrides": {
    "encoding-sniffer": "^1.0.2"
  }
}
