#!/bin/sh
set -eu

cd "$(git rev-parse --show-toplevel)"

echo "Running pre-push checks..."

remote=${1:-origin}
publish_branches=""
current_branch=$(git branch --show-current)

while read -r local_ref _local_sha remote_ref _remote_sha; do
  if [ "${remote_ref#refs/heads/}" != "$remote_ref" ]; then
    pushed_branch=${remote_ref#refs/heads/}
    case "$pushed_branch" in
      plugins/*|*/plugins/*) ;;
      *) publish_branches="$publish_branches $pushed_branch" ;;
    esac
  elif [ "$local_ref" = "HEAD" ] && [ -n "$current_branch" ]; then
    case "$current_branch" in
      plugins/*|*/plugins/*) ;;
      *) publish_branches="$publish_branches $current_branch" ;;
    esac
  fi
done

HOOK_DIR=$(dirname "$0")
"$HOOK_DIR/pre-commit"

rm -rf .dist .js total.svg
node scripts/generate-plugin-index.js

if ! git diff --exit-code -- plugins/index.ts; then
  echo "plugins/index.ts is out of sync with the plugins directory."
  echo "Run 'node scripts/generate-plugin-index.js' and commit the updated index."
  exit 1
fi

npm run build:compile

VERSION=$(node -e "console.log(require('./package.json').version)")
BRANCH="plugins/v$VERSION" npm run build:manifest
npm run verify:plugins

for publish_branch in $publish_branches; do
  ./scripts/publish-plugins.sh "$remote" "$publish_branch"
done
